# Fichier de référence.
# Gestion recommandée: utiliser un profil dans `transcendence/env/profiles/*.env`
# puis l'appliquer avec:
#   make env-list
#   make env-use PROFILE=local    # machine locale (https://localhost)
#   make env-use PROFILE=lan      # adapte APP_ORIGIN à ton IP LAN (téléphone, etc.)
#
# À quoi servent APP_ORIGIN et NGINX_SERVER_NAME ?
# - APP_ORIGIN : URL publique de l’app (schéma + hôte + port si besoin), ex. https://192.168.1.26
#   → Django (CSRF, OAuth redirect), variables VITE_* du frontend, liens absolus.
# - NGINX_SERVER_NAME : valeur nginx `server_name` (Host attendu). Avec `default_server` dans
#   nginx, une IP ou un domaine fonctionne ; garde la même « base » que APP_ORIGIN (sans https://).
#
# Ce fichier reste un aide-memoire global.
#
# PostgreSQL — utilisé au premier démarrage du conteneur `db` uniquement.
# Si tu changes POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB alors que le dossier
# `transcendence/database/data` existe déjà, Postgres ne ré-exécute pas l’init :
# les connexions échouent (rôle inconnu / mauvais mot de passe). Dans ce cas :
#   make down
#   rm -rf transcendence/database/data
#   make up-bg
# (perte des données locales de dev), puis `make migrations`.
POSTGRES_DB=transcendence
POSTGRES_USER=cloe
POSTGRES_PASSWORD=password_ici

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=pwGrafana

ELASTIC_PASSWORD=pwElastic
KIBANA_PASSWORD=pwKibana

REDIS_PASSWORD=keL3Rad

VAULT_ROOT_TOKEN=pwVault

# URL canonique de l'application (Nginx en frontal)
# Exemples:
# - local: https://localhost
# - LAN:   https://192.168.1.26
APP_ORIGIN=https://localhost

# Hostname servi par nginx (server_name)
NGINX_SERVER_NAME=localhost

# Django sécurité réseau
DJANGO_ALLOWED_HOSTS=backend,localhost,127.0.0.1,0.0.0.0
DJANGO_CSRF_TRUSTED_ORIGINS=https://localhost,https://127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=https://localhost,http://localhost:5173

# OAuth 42 / URLs (laisser vides en dev local si non utilisés — évite les WARN compose)
FORTYTWO_CLIENT_ID=
FORTYTWO_CLIENT_SECRET=
FORTYTWO_REDIRECT_URI=https://localhost/api/auth/42/callback/
FRONTEND_DASHBOARD_URL=https://localhost/dashboard

# Frontend/Vite optionnel (sinon basé sur APP_ORIGIN)
VITE_API_ORIGIN=
VITE_WS_ORIGIN=
VITE_HMR_HOST=localhost
VITE_PROXY_TARGET=https://127.0.0.1:443

# Email/SMTP (2FA emails)
# Dev default (MailHog): open http://localhost:8025 to read emails.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=noreply@transcendence.local
EMAIL_HOST=mailhog
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Optional real SMTP example (replace values if you want real mailbox delivery):
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your_email@gmail.com
# EMAIL_HOST_PASSWORD=your_app_password
