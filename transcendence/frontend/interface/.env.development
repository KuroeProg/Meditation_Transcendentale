# Chargé par Vite uniquement en `npm run dev` (mode development), pas en `vite build`.
# Les variables front doivent vivre ici ou dans .env.local à la racine de ce dossier — pas dans transcendence/.env.
# Activer le flux choixpeau après inscription locale (coalition vide → cérémonie → PUT /api/auth/me/update).
# Mise à `false` seulement si tu veux désactiver volontairement la pop-up en dev.
VITE_SORTING_HAT_COALITION=true
