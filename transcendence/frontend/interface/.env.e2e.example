# Playwright E2E configuration
# Copy this file to `.env.e2e` and fill real test credentials.

E2E_BASE_URL=https://localhost

# Shared smoke/auth account
E2E_SMOKE_USER_EMAIL=smoke@example.com
E2E_SMOKE_USER_PASSWORD=change-me

# Matchmaking pair 1
E2E_USER_A_EMAIL=user-a@example.com
E2E_USER_A_PASSWORD=change-me
E2E_USER_B_EMAIL=user-b@example.com
E2E_USER_B_PASSWORD=change-me

# Optional additional accounts for future scenarios
E2E_USER_C_EMAIL=user-c@example.com
E2E_USER_C_PASSWORD=change-me
