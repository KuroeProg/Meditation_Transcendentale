# Optionnel : origine HTTPS où tourne Django + cookies de session (OAuth callback).
# Par défaut en dev, le front utilise https://localhost pour la redirection login 42.
# VITE_API_ORIGIN=https://localhost

# Optionnel : origine explicite WebSocket (si différente de VITE_API_ORIGIN / window.location.origin).
# Ex: wss://localhost
# VITE_WS_ORIGIN=wss://localhost

# Si ton nginx écoute sur un autre hôte/port, adapte aussi vite.config.js (proxy /api).

# --- Mock utilisateur (npm run dev uniquement) ---
# Copier ce bloc dans .env.local à la racine de interface/ (pas transcendence/.env).
# Rappel des variables : make mock-help
#
# VITE_DEV_MOCK_USER=true
# VITE_MOCK_COALITION=eau
# VITE_MOCK_AUTH_PROVIDER=oauth42
# VITE_MOCK_USER_ID=42
# VITE_MOCK_RESET_SORTING_HAT=true
#
# Choixpeau en mock : VITE_MOCK_AUTH_PROVIDER=local (coalition vide ou pending_hat)
# Partie à deux (échiquier) : blancs = mockSessionUser, noirs = mockGameOpponent.js
